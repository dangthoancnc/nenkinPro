generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  COLLABORATOR
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String
  name      String
  role      Role    @default(COLLABORATOR)
  staffCode String? @unique

  customers Customer[]

  sessions          StaffSession[]
  templateDrafts    TemplateDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nenkin_users")
}

model StaffSession {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  ipHash     String?
  userAgent  String?

  @@index([userId])
  @@index([expiresAt])
  @@map("nenkin_staff_sessions")
}

model CustomerSession {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  ipHash     String?
  userAgent  String?

  @@index([customerId])
  @@index([expiresAt])
  @@map("nenkin_customer_sessions")
}

model OcrResult {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  documentType String   // Ví dụ: 'zairyuFront', 'passport'
  rawData      Json     // Lưu toàn bộ cục JSON do AI trả về
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Mỗi khách hàng chỉ có 1 bản lưu OCR mới nhất cho mỗi loại giấy tờ
  @@unique([customerId, documentType]) 
  @@map("nenkin_ocr_results")
}

model TemplateDraft {
  id             String   @id @default(uuid())

  /// ID của DocumentTemplate trong static registry (kebab-case)
  templateId     String

  /// Version ID trong registry làm gốc để fork
  baseVersionId  String

  /// Số thứ tự draft: tự tăng theo templateId
  draftNumber    Int

  /// Nội dung fieldMappings JSON — phải pass FieldMappingSchema[]
  fieldMappings  Json

  changeNote     String
  createdById    String

  /// User tạo draft — relation tới model User hiện có
  createdBy      User     @relation(fields: [createdById], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([templateId, draftNumber])
  @@index([templateId])
  @@index([createdById])
  @@map("nenkin_template_drafts")
}

model Customer {
  id          String         @id @default(uuid())
  code        String         @unique
  cardNumber  String?        @unique
  fullName    String
  dob         DateTime
  passwordPin String?
  pinResetRequired Boolean @default(false)
  status      CustomerStatus @default(NEW)

  zairyuAddress       String?
  zairyuRomajiAddress String?
  postalCode          String?
  taxOfficeId         String?
  nenkinNumber        String?
  nenkinKatakanaName  String?

  nenkinBookUrl     String?
  zairyuFrontUrl    String?
  zairyuBackUrl     String?
  passportUrl       String?
  departureStampUrl String?
  
  bankAccounts      BankAccount[]
  securityPhotoUrl  String? // Chứa ảnh chụp chân dung bảo mật

  lastName               String?
  firstName              String?
  fullNameFurigana       String?
  nationality            String?
  sex                    String?
  placeOfBirth           String?
  passportIssueDate      DateTime?
  passportExpiryDate     DateTime?
  phone                  String?
  overseasAddress        String?
  overseasCountry        String?
  hasPermanentResidence  Boolean?
  permanentResidenceDate DateTime?
  myNumber               String?
  occupation             String?
  departureDate          DateTime?
  headOfHouseholdName    String?
  relationshipToHead     String?
  pensionSystemRegistrationNumber String?

  overseasStreet         String?
  overseasCity           String?
  overseasProvince       String?
  overseasPostalCode     String?

  applications     NenkinApplication[]
  workHistories    WorkHistory[]
  ocrResults       OcrResult[]
  sessions         CustomerSession[]

  createdBy   User?   @relation(fields: [createdById], references: [id])
  createdById String?

  zaloContact            String?
  facebookContact        String?
  referralCode           String?        @unique
  referredByCode         String?

  referralType          ReferralType?
  referredByCustomerId  String?
  referredByCustomer    Customer?  @relation("CustomerReferrals", fields: [referredByCustomerId], references: [id], onDelete: SetNull)
  referrals             Customer[] @relation("CustomerReferrals")

  taxOffice TaxOffice? @relation(fields: [taxOfficeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nenkin_customers")
}

enum CustomerStatus {
  NEW
  PENDING
  VERIFIED
}

enum ReferralType {
  STAFF
  CUSTOMER
}

enum ApplicationStatus {
  PENDING
  DRAFT
  REVISION_REQUIRED
  SENT_1ST
  RECEIVED_1ST
  SENT_2ND
  RECEIVED_2ND
  COMPLETED
  CANCELLED
}

model NenkinApplication {
  id         String @id @default(uuid())
  status ApplicationStatus @default(DRAFT)
  revisionNote String? // Ghi chú yêu cầu sửa chữa từ nhân viên


  applyDate       DateTime?
  sent1stDate     DateTime?
  received1stDate DateTime?
  sent2ndDate     DateTime?
  received2ndDate DateTime?

  // --- Lần 1 & Notice of Payment ---
  noticeDate      DateTime? // Ngày ra thông báo cấp Lần 1
  noticeImageUrl  String?   // Ảnh chụp Phiếu thông báo Lần 1
  
  totalExpectedJpy Decimal? // 支給額 - Tổng tiền
  received1stJpy   Decimal? // 控除後支払額 - Tiền thực nhận Lần 1
  received2ndJpy   Decimal? // Thực nhận Lần 2
  tax2ndJpy        Decimal? // 所得税額 - Tiền thuế Lần 2 (Access ThueLan2)
  withheldTax      Decimal? // Thuế đã khấu trừ (源泉徴収税額) 20.42%

  serviceFeeJpy Decimal?
  exchangeRate  Decimal?
  serviceFeeVnd Decimal?
  
  referralBonusJpy    Decimal?  // +2000 JPY commission cho CTV giới thiệu
  referralDiscountJpy Decimal?  // -2000 JPY giảm giá cho khách hàng được giới thiệu
  
  targetGroup   String?    // Equivalent to DoiTuong from Access
  taxYear       Int?       // Năm khai thuế Reiwa
  workYears     Int?       // Số năm làm việc

  customerId          String
  customer            Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  taxRepresentativeId String?
  taxRepresentative   TaxRepresentative?  @relation(fields: [taxRepresentativeId], references: [id])

  histories           ApplicationHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nenkin_applications")
}

model ApplicationHistory {
  id            String             @id @default(uuid())
  applicationId String
  application   NenkinApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  actorName     String
  action        String
  description   String
  createdAt     DateTime           @default(now())

  @@index([applicationId])
  @@map("nenkin_application_histories")
}

model TaxRepresentative {
  id            String  @id @default(uuid())
  fullName      String
  fullNameKana  String?
  address       String
  postalCode    String
  phone         String?
  myNumber      String?
  relationship  String? @default("納税管理人")
  
  bankName      String?
  branchName    String?
  accountNumber String?
  accountName   String?

  applications  NenkinApplication[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("nenkin_tax_representatives")
}

model TaxOffice {
  id                String  @id @default(uuid())
  name              String
  romajiName        String?
  address           String
  romajiAddress     String?
  postalCode        String
  phone             String?
  mapUrl            String?
  websiteUrl        String?
  receptionInfo     String?
  notes             String?

  // --- Các trường thông tin phục vụ gửi hồ sơ và tra cứu chi tiết ---
  mailingName       String?  // 申告書等の郵送先 (Tên trung tâm/cục thuế nhận)
  mailingPostalCode String?  // 申告書等の郵送先 (Mã bưu điện nhận)
  mailingAddress    String?  // 申告書等の郵送先 (Địa chỉ nhận)
  jurisdiction      String?  // 管轄区域 (Khu vực quản lý)
  consultationPhone String?  // 電話相談の方 (SĐT tư vấn)
  generalPhone      String?  // 電話相談以外で税務署にご用の方 (SĐT hành chính)

  customers Customer[]

  @@map("nenkin_tax_offices")
}


model ExchangeRate {
  id        String   @id @default(uuid())
  date      DateTime @unique
  jpyToVnd  Decimal
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nenkin_exchange_rates")
}

model WorkHistory {
  id             String    @id @default(uuid())
  customerId     String
  companyName    String
  companyAddress String?
  startDate      DateTime?
  endDate        DateTime?
  pensionType    String?   @default("厚生年金保険")

  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("nenkin_work_histories")
}

enum EntityType {
  CUSTOMER
  APPLICATION
}

model AuditLog {
  id          String     @id @default(uuid())
  entityId    String     // ID của Customer hoặc NenkinApplication
  entityType  EntityType // Loại đối tượng bị thay đổi
  fromState   String     // Trạng thái trước khi chuyển (vd: DRAFT)
  toState     String     // Trạng thái sau khi chuyển (vd: SENT_1ST)
  actionBy    String     // ID của người dùng (User hoặc Customer) thực hiện
  actionAt    DateTime   @default(now()) // Thời gian thực hiện chuyển đổi
  metadata    Json?      // Lưu JSON chi tiết: lý do từ chối (revision note), IP, User-Agent, hoặc các fields thay đổi quan trọng
  
  @@index([entityId, entityType])
  @@index([actionAt])
  @@map("nenkin_audit_logs")
}

model BankDictionary {
  id          String   @id @default(uuid())
  country     String   // 'JAPAN' | 'VIETNAM'
  bankName    String
  branchName  String?
  swiftCode   String?
  address     String?
  city        String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([country, bankName, branchName])
  @@map("nenkin_bank_dictionaries")
}

model BankAccount {
  id                  String   @id @default(uuid())
  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  purpose             String   // 'FIRST_REFUND' | 'SECOND_REFUND' | 'BOTH'
  bankCountry         String   // 'JAPAN' | 'VIETNAM'
  bankPassbookUrls    String[] @default([])
  
  bankName            String?
  branchName          String?
  accountNumber       String?
  accountName         String?
  accountNameKatakana String?  
  
  swiftCode           String?
  bankBranchAddress   String?
  bankInstitutionCode String?
  branchCode          String?
  bankAccountType     String?  // ORDINARY (1) hoặc CURRENT (2)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("nenkin_bank_accounts")
}
