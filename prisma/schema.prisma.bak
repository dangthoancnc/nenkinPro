generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  COLLABORATOR
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String
  name      String
  role      Role    @default(COLLABORATOR)
  staffCode String? @unique

  customers Customer[]

  transfersSent     TransferRequest[] @relation("TransfersSent")
  transfersReceived TransferRequest[] @relation("TransfersReceived")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nenkin_users")
}

model Customer {
  id          String         @id @default(uuid())
  code        String         @unique
  cardNumber  String?        @unique
  fullName    String
  dob         DateTime
  passwordPin String?
  status      CustomerStatus @default(NEW)

  zairyuAddress       String?
  zairyuRomajiAddress String?
  postalCode          String?
  taxOfficeId         String?
  nenkinNumber        String?

  bankName      String?
  branchName    String?
  accountNumber String?
  accountName   String?
  swiftCode     String?

  zairyuFrontUrl    String?
  zairyuBackUrl     String?
  passportUrl       String?
  departureStampUrl String?
  nenkinBookUrl     String?
  bankPassbookUrl   String?

  lastName               String?
  firstName              String?
  fullNameFurigana       String?
  nationality            String?
  sex                    String?
  placeOfBirth           String?
  passportIssueDate      DateTime?
  passportExpiryDate     DateTime?
  phone                  String?
  overseasAddress        String?
  overseasCountry        String?
  hasPermanentResidence  Boolean?
  permanentResidenceDate DateTime?
  myNumber               String?
  bankBranchAddress      String?
  bankCountry            String?
  occupation             String?
  departureDate          DateTime?
  headOfHouseholdName    String?
  relationshipToHead     String?

  applications     NenkinApplication[]
  transferRequests TransferRequest[]

  createdBy   User?   @relation(fields: [createdById], references: [id])
  createdById String?

  taxOffice TaxOffice? @relation(fields: [taxOfficeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nenkin_customers")
}

enum CustomerStatus {
  NEW
  PENDING
  VERIFIED
}

enum ApplicationStatus {
  PENDING
  DRAFT
  SENT_1ST
  RECEIVED_1ST
  SENT_2ND
  RECEIVED_2ND
  COMPLETED
  CANCELLED
}

model NenkinApplication {
  id         String @id @default(uuid())
  status ApplicationStatus @default(DRAFT)

  applyDate       DateTime?
  sent1stDate     DateTime?
  received1stDate DateTime?
  sent2ndDate     DateTime?
  received2ndDate DateTime?

  // --- Lần 1 & Notice of Payment ---
  noticeDate      DateTime? // Ngày ra thông báo cấp Lần 1
  noticeImageUrl  String?   // Ảnh chụp Phiếu thông báo Lần 1
  
  totalExpectedJpy Decimal? // 支給額 - Tổng tiền
  received1stJpy   Decimal? // 控除後支払額 - Tiền thực nhận Lần 1
  received2ndJpy   Decimal? // Thực nhận Lần 2
  tax2ndJpy        Decimal? // 所得税額 - Tiền thuế Lần 2 (Access ThueLan2)

  serviceFeeJpy Decimal?
  exchangeRate  Decimal?
  serviceFeeVnd Decimal?
  
  targetGroup   String?    // Equivalent to DoiTuong from Access

  customerId          String
  customer            Customer            @relation(fields: [customerId], references: [id])
  
  taxRepresentativeId String?
  taxRepresentative   TaxRepresentative?  @relation(fields: [taxRepresentativeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nenkin_applications")
}

model TaxRepresentative {
  id            String  @id @default(uuid())
  fullName      String
  fullNameKana  String?
  address       String
  postalCode    String
  phone         String?
  myNumber      String?
  
  bankName      String?
  branchName    String?
  accountNumber String?
  accountName   String?

  applications  NenkinApplication[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("nenkin_tax_representatives")
}

model TaxOffice {
  id            String  @id @default(uuid())
  name          String
  romajiName    String?
  address       String
  romajiAddress String?
  postalCode    String
  phone         String?
  mapUrl        String?
  websiteUrl    String?
  receptionInfo String?
  notes         String?

  customers Customer[]

  @@map("nenkin_tax_offices")
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

model TransferRequest {
  id         String         @id @default(uuid())
  customerId String
  fromUserId String
  toUserId   String
  status     TransferStatus @default(PENDING)
  notes      String?

  customer Customer @relation(fields: [customerId], references: [id])
  fromUser User     @relation("TransfersSent", fields: [fromUserId], references: [id])
  toUser   User     @relation("TransfersReceived", fields: [toUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nenkin_transfer_requests")
}
